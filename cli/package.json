{
  "name": "@reshapr/reshapr-cli",
  "version": "0.0.2-SNAPSHOT",
  "description": "CLI for reshapr.io - The MCP Gateway for AI-Native API Access!",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "reshapr": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reshaprio/reshapr.git"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/cli.ts",
    "prebuild": "node -p \"'export const CLI_VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "get-port": "^7.1.0",
    "inquirer": "^12.7.0",
    "js-yaml": "^4.1.0",
    "open": "^10.2.0",
    "yocto-spinner": "^1.0.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.13",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">= 20"
  }
}
