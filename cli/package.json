{
  "name": "@reshapr/reshapr-cli",
  "version": "0.0.14-SNAPSHOT",
  "description": "CLI for reshapr.io - The MCP Gateway for AI-Native API Access!",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "reshapr": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reshaprio/reshapr.git"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/cli.ts",
    "prebuild": "node -p \"'export const CLI_VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@scarf/scarf": "1.4.0",
    "chalk": "5.6.2",
    "cli-highlight": "2.1.11",
    "commander": "14.0.3",
    "get-port": "7.2.0",
    "inquirer": "13.4.3",
    "js-yaml": "4.1.1",
    "open": "11.0.0",
    "yocto-spinner": "1.2.0"
  },
  "devDependencies": {
    "@types/commander": "2.12.5",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.0.13",
    "execa": "9.6.1",
    "typescript": "5.8.3",
    "vitest": "4.1.7"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">= 20"
  }
}
